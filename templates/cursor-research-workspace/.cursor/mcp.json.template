{
  "mcpServers": {
    "ir_search": {
      "command": "{{IR_SEARCH_PYTHON}}",
      "args": ["-m", "ir_search.mcp_server"],
      "env": {
        "IR_SEARCH_LIVE": "{{IR_SEARCH_LIVE}}",
        "BOCHA_API_KEY": "${env:BOCHA_API_KEY}",
        "EXA_API_KEY": "${env:EXA_API_KEY}",
        "TAVILY_API_KEY": "${env:TAVILY_API_KEY}",
        "ANYSEARCH_API_KEY": "${env:ANYSEARCH_API_KEY}",
        "MANUAL_WECHAT_ROOT": "{{MANUAL_WECHAT_ROOT}}",
        "IR_SEARCH_CACHE_DIR": "{{IR_SEARCH_CACHE_DIR}}"
      }
    }
  }
}
